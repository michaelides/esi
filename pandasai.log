import pandas as pd
from scipy import stats

# Write code here

# Perform ANOVA test
try:
    # Group the 'Value' column by 'Ticker Symbol'
    grouped_data = dfs[0].groupby('Ticker Symbol')['Value'].apply(list)

    # Perform ANOVA test
    f_statistic, p_value = stats.f_oneway(*grouped_data)

    # Interpret the results
    if p_value < 0.05:
        result_string = f"The p-value is {p_value:.3f}, which is less than 0.05. There is a statistically significant difference in 'Value' among the different 'Ticker Symbol' groups."
    else:
        result_string = f"The p-value is {p_value:.3f}, which is not less than 0.05. There is no statistically significant difference in 'Value' among the different 'Ticker Symbol' groups."

    # Declare result var:
    result = { "type": "string", "value": result_string }

except Exception as e:
    result = { "type": "string", "value": f"An error occurred: {e}" }
